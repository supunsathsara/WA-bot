# WhatsApp Meta
VERIFY_TOKEN=your_secure_random_string
WHATSAPP_TOKEN=your_whatsapp_permanent_access_token

# Admin & Permissions
ADMIN_NUMBER=1234567890

# Databases & Infrastructure
SUPABASE_PROJECT_ID=your_supabase_project_id
SUPABASE_SECRET_KEY=your_supabase_service_role_key
REDIS_URL=your_upstash_redis_rest_url

# Sri Lanka Train Schedule Scraper (Optional)
TRAIN_UN=your_srilanka_railway_email
TRAIN_PASS=your_srilanka_railway_password

# AI Engines
GROQ_API_KEY=your_groq_api_key
HUGGINGFACE_API_KEY=your_huggingface_inference_key
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Serverless Background Queue (Upstash Workflow)
APP_URL=https://your-bot-url.vercel.app
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key
QSTASH_URL=https://qstash-us-east-1.upstash.io # Optional (Only if using a specific region)

# Logging & Monitoring
AXIOM_TOKEN=your_axiom_api_token
AXIOM_DATASET=wa-bot
CRON_SECRET=secure_string_for_cron_jobs
