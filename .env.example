VERIFY_TOKEN=my_secret_token
WHATSAPP_TOKEN=your_whatsapp_access_token_here

# Supabase
SUPABASE_PROJECT_ID=your_project_id
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PUBLISH_KEY=sb_publishable_...
SUPABASE_DB_PASS=your_db_password

# Access Control
# Comma-separated list of allowed WhatsApp numbers (include country code, e.g. +94701234567)
# Set to * to allow all numbers (open access)
ALLOWED_NUMBERS=+94701234567,+94709876543
ADMIN_NUMBER=+94701234567

# Vercel Cron (generate with: openssl rand -hex 32)
CRON_SECRET=your_random_secret_here
